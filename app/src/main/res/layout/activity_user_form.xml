<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical"
    tools:context=".activities.dashboard.UserFormActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClose"
            style="@style/Widget.SenCare.Button.Coral"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="✕"
            android:textSize="18sp"
            android:padding="0dp"
            app:cornerRadius="22dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_title"
                android:paddingHorizontal="18dp"
                android:paddingVertical="12dp"
                android:layout_marginTop="24dp"
                android:text="Nhập thông tin đăng ký"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivAvatar"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_marginTop="40dp"
                android:scaleType="centerCrop"
                android:src="@drawable/icon"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:strokeColor="@color/mint"
                app:strokeWidth="4dp" />

            <!-- Hai nút chọn ảnh / chụp ảnh -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChoosePhoto"
                    style="@style/Widget.SenCare.Button.Primary"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginEnd="12dp"
                    android:text="Chọn ảnh"
                    android:textSize="14sp"
                    android:paddingHorizontal="20dp"
                    app:cornerRadius="20dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTakePhoto"
                    style="@style/Widget.SenCare.Button.Accent"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:text="Chụp ảnh"
                    android:textSize="14sp"
                    android:paddingHorizontal="20dp"
                    app:cornerRadius="20dp" />

            </LinearLayout>

            <!-- Nhãn + ô nhập tên hiển thị -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tên hiển thị :"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/etDisplayName"
                    android:layout_width="180dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_edittext"
                    android:paddingHorizontal="14dp"
                    android:inputType="textPersonName"
                    android:singleLine="true"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:hint="" />

            </LinearLayout>

            <!-- Nút lưu thông tin -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                style="@style/Widget.SenCare.Button.Primary"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:layout_marginTop="28dp"
                android:text="Lưu thông tin"
                android:textSize="16sp"
                android:paddingHorizontal="40dp"
                app:cornerRadius="25dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
