<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme: nền trắng, tông mint pastel. -->
    <style name="Base.Theme.SenCare" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:fontFamily">@font/nunito</item>
        <item name="colorPrimary">@color/mint</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/mint_pale</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>
        <item name="colorSecondary">@color/accent_yellow</item>
        <item name="colorOnSecondary">@color/on_accent</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/mint_surface</item>
        <item name="android:statusBarColor">@color/mint</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.SenCare" parent="Base.Theme.SenCare" />

    <style name="CircleImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- ===== Nút bấm dùng lại ===== -->
    <style name="Widget.SenCare.Button" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">26dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- Nút chính (mint, chữ trắng) -->
    <style name="Widget.SenCare.Button.Primary">
        <item name="backgroundTint">@color/mint</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Nút nhấn phụ (vàng pastel, chữ đậm) -->
    <style name="Widget.SenCare.Button.Accent">
        <item name="backgroundTint">@color/accent_yellow</item>
        <item name="android:textColor">@color/on_accent</item>
    </style>

    <!-- Nút cảnh báo / thoát (đỏ pastel, chữ trắng) -->
    <style name="Widget.SenCare.Button.Coral">
        <item name="backgroundTint">@color/accent_coral</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Nút viền (nền trắng, viền mint) -->
    <style name="Widget.SenCare.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">26dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeColor">@color/mint</item>
        <item name="strokeWidth">2dp</item>
    </style>

    <!-- Nút quay lại: hình tròn đỏ pastel, mũi tên trắng -->
    <style name="Widget.SenCare.BackButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent_coral</item>
        <item name="iconTint">@color/white</item>
        <item name="iconPadding">0dp</item>
        <item name="cornerRadius">22dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingRight">0dp</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- ===== Chữ dùng lại ===== -->
    <style name="Text.SenCare" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/nunito</item>
    </style>

    <style name="Text.SenCare.Heading">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.SenCare.Label">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
