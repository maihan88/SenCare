<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_app"
    android:fitsSystemWindows="true"
    tools:context=".activities.auth.RegisterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClose"
            style="@style/Widget.SenCare.Button.Coral"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="✕"
            android:textSize="18sp"
            android:padding="0dp"
            app:cornerRadius="22dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_login_box"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@drawable/bg_title"
                android:paddingHorizontal="18dp"
                android:paddingVertical="12dp"
                android:text="Nhập thông tin đăng ký"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/label_username"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/edtUsername"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_edittext"
                android:hint="@string/hint_username"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:paddingHorizontal="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/label_password"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/edtPassword"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_edittext"
                android:hint="@string/hint_password"
                android:inputType="textPassword"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:paddingHorizontal="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/label_confirm_password"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/edtConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_edittext"
                android:hint="@string/hint_password"
                android:inputType="textPassword"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:paddingHorizontal="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/label_email"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/edtEmail"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_edittext"
                android:hint="@string/hint_email"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:paddingHorizontal="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/label_role"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <RadioButton
                    android:id="@+id/radiospinnerUser"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="User"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/mint"
                    android:background="@drawable/bg_edittext"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp" />

                <RadioButton
                    android:id="@+id/radiospinnerSpa"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Spa"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/mint"
                    android:background="@drawable/bg_edittext"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                style="@style/Widget.SenCare.Button.Primary"
                android:layout_width="160dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:text="@string/action_register"
                android:textSize="16sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
