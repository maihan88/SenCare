<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/background"
    tools:context=".activities.auth.RegisterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="16dp"
        android:gravity="end">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="X"
            android:textColor="@color/white"
            android:backgroundTint="#ff7171"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="18dp"
            style="@style/Widget.MaterialComponents.Button" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="320dp"
        android:layout_height="645dp"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_login_box"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_title"
            android:padding="12dp"
            android:text="Nhập thông tin đăng ký"
            android:textColor="#5A7E9B"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Tên đăng nhập"
            android:textColor="#5A7E9B"
            android:textSize="20dp" />

        <EditText
            android:id="@+id/edtUsername"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/bg_edittext"
            android:hint="Nhập tên đăng nhập của bạn"
            android:padding="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Mật khẩu"
            android:textColor="#5A7E9B"
            android:textSize="20dp" />

        <EditText
            android:id="@+id/edtPassword"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/bg_edittext"
            android:hint="Nhập mật khẩu từ 7-13 ký tự"
            android:inputType="textPassword"
            android:padding="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Xác nhận mật khẩu"
            android:textColor="#5A7E9B"
            android:textSize="20dp" />

        <EditText
            android:id="@+id/edtConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/bg_edittext"
            android:hint="Nhập mật khẩu từ 7-13 ký tự"
            android:inputType="textPassword"
            android:padding="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Địa chỉ Email"
            android:textColor="#5A7E9B"
            android:textSize="20dp" />

        <EditText
            android:id="@+id/edtEmail"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/bg_edittext"
            android:hint="Nhập Email có đuôi @gmail"
            android:padding="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Vai trò"
            android:textColor="#5A7E9B"
            android:textSize="20dp" />
        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <RadioButton
                android:id="@+id/radiospinnerUser"
                android:layout_width="100dp"
                android:layout_height="55dp"
                android:text="User"
                android:background="@drawable/bg_edittext"
                android:layout_marginLeft="20dp"
                android:padding="12dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
            <RadioButton
                android:id="@+id/radiospinnerSpa"
                android:layout_width="100dp"
                android:layout_height="55dp"
                android:text="Spa"
                android:layout_marginLeft="40dp"
                android:background="@drawable/bg_edittext"
                android:padding="12dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"/>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            android:layout_width="130dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:layout_marginTop="10sp"
            android:backgroundTint="#E7FD7B"
            android:text="Đăng ký"
            android:textColor="#4A89B0"
            android:textSize="15sp"
            android:textStyle="bold"
            app:cornerRadius="26dp"
            app:strokeColor="#44C7AE"
            app:strokeWidth="4dp" />

        <TextView
            android:id="@+id/tvForgotPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="1dp"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="48dp"
            android:text="Quên mật khẩu?"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>
</LinearLayout>