<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SenCare"
        android:usesCleartextTraffic="true">

        <!--
             TODO: Before you run your application, you need a Google Maps API key.

             To get one, follow the directions here:

                https://developers.google.com/maps/documentation/android-sdk/get-api-key

             Once you have your API key (it starts with "AIza"), define a new property in your
             project's local.properties file (e.g. MAPS_API_KEY=Aiza...), and replace the
             "YOUR_API_KEY" string in this file with "${MAPS_API_KEY}".
        -->
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <activity
            android:name=".activities.MapTest"
            android:exported="false"
            android:label="@string/title_activity_map_test" />
        <activity
            android:name=".activities.vet.VetMapActivity"
            android:exported="false" />
        <activity
            android:name=".activities.booking.BookingListActivity"
            android:exported="false" />
        <activity
            android:name=".activities.booking.BookingFormActivity"
            android:exported="false" />
        <activity
            android:name=".activities.booking.SpaDetailActivity"
            android:exported="false" />
        <activity
            android:name=".activities.booking.SpaMapActivity"
            android:exported="false" />
        <activity
            android:name=".activities.booking.SpaSearchActivity"
            android:exported="false" />
        <activity
            android:name=".activities.spaowner.SpaProfileActivity"
            android:exported="false" />
        <activity
            android:name=".activities.spaowner.SpaFormActivity"
            android:exported="false" />
        <activity
            android:name=".activities.diary.DiaryDetailActivity"
            android:exported="false" />
        <activity
            android:name=".activities.diary.AddDiaryActivity"
            android:exported="false" />
        <activity
            android:name=".activities.diary.DiaryTimelineActivity"
            android:exported="false" />
        <activity
            android:name=".activities.diary.PetDiaryListActivity"
            android:exported="false" />
        <activity
            android:name=".activities.pet.PetDetailActivity"
            android:exported="false" />
        <activity
            android:name=".activities.pet.PetFormActivity"
            android:exported="false" />
        <activity
            android:name=".activities.pet.PetListActivity"
            android:exported="false" />
        <activity
            android:name=".activities.dashboard.SpaOwnerHomeActivity"
            android:exported="false" />
        <activity
            android:name=".activities.dashboard.UserHomeActivity"
            android:exported="false" />
        <activity
            android:name=".activities.profile.ProfileActivity"
            android:exported="false" />
        <activity
            android:name=".activities.auth.ForgotPasswordActivity"
            android:exported="false" />
        <activity
            android:name=".activities.auth.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".activities.auth.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>