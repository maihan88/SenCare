<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/backgroundspa"
    tools:context=".activities.spaowner.SpaProfileActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="16dp"
        android:gravity="end">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReturn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="x"
            android:textSize="25dp"
            android:layout_gravity="center"
            android:textColor="@color/white"
            android:backgroundTint="#ff7171"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="18dp"
            style="@style/Widget.MaterialComponents.Button" />
    </LinearLayout>

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivSpaAvatar"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="56dp"
        android:scaleType="centerCrop"
        android:src="@drawable/icon"
        app:shapeAppearanceOverlay="@style/CircleImage"
        app:strokeColor="#CCCCCC"
        app:strokeWidth="4dp" />

    <TextView
        android:id="@+id/tvSpaName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/ivSpaAvatar"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:text="Thái Minh Trí"
        android:textColor="#1B5E40"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="0.03" />

    <TextView
        android:id="@+id/tvSpaEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvSpaName"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="4dp"
        android:text="spaxyz@gmail.com"
        android:textColor="#555555"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogin"
        android:layout_width="200dp"
        android:layout_height="52dp"
        android:layout_below="@id/tvSpaEmail"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="36dp"
        android:backgroundTint="#E7FD7B"
        android:text="Chỉnh sữa thông tin"
        android:textColor="#4A89B0"
        android:textSize="15sp"
        android:textStyle="bold"
        app:cornerRadius="26dp"
        app:strokeColor="#44C7AE"
        app:strokeWidth="4dp" />

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="250dp"
        android:layout_height="90dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="32dp"
        android:src="@drawable/logo" />

</RelativeLayout>